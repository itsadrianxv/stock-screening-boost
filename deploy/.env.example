# Docker Compose project name
COMPOSE_PROJECT_NAME=stock-screening-boost

# Host ports (Windows + WSL both use localhost access)
WEB_PORT=3000
PYTHON_SERVICE_PORT=8000
POSTGRES_PORT=5432

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=stock-screening-boost

# NextAuth / Auth.js
# Generate with: npx auth secret
AUTH_SECRET=replace-with-a-random-secret
# Optional: keep previous secrets for JWT decryption during secret rotation
AUTH_SECRET_1=
AUTH_SECRET_2=
AUTH_SECRET_3=
# Legacy alias, kept for backwards compatibility
NEXTAUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Optional WeChat OAuth provider
AUTH_WECHAT_ID=
AUTH_WECHAT_SECRET=

# Optional QQ OAuth provider
AUTH_QQ_ID=
AUTH_QQ_SECRET=

# Local credentials provider (fallback)
AUTH_CREDENTIALS_USERNAME=admin
AUTH_CREDENTIALS_PASSWORD=admin123456

# Runtime service endpoints (inside docker network)
REDIS_URL=redis://redis:6379
PYTHON_SERVICE_URL=http://python-service:8000/api
PYTHON_INTELLIGENCE_SERVICE_URL=http://python-service:8000

# Workflow worker (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=https://api.firecrawl.dev
FIRECRAWL_TIMEOUT_MS=15000
WORKFLOW_WORKER_POLL_INTERVAL_MS=2000

# Screening worker
SCREENING_WORKER_POLL_INTERVAL_MS=2000

# Python service CORS
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:3001
INTELLIGENCE_CACHE_TTL_SECONDS=300
INTELLIGENCE_CACHE_STALE_SECONDS=1800
INTELLIGENCE_SPOT_CACHE_TTL_SECONDS=120
INTELLIGENCE_ENABLE_MOCK_FALLBACK=true
